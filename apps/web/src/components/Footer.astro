        <li><a href="https://status.trendora.tanesolutions.com" class="hover:text-foreground">Status</a></li>
      </ul>
    </div>

    <div>
      <h3 class="font-medium mb-3">Empresa</h3>
      <ul class="space-y-2 text-tane-muted">
        <li><a href="/sobre-nosotros" class="hover:text-foreground">Sobre Tane</a></li>
        <li><a href="/contacto" class="hover:text-foreground">Contacto</a></li>
        <li><a href="/legal/privacidad" class="hover:text-foreground">Privacidad</a></li>
        <li><a href="/legal/terminos" class="hover:text-foreground">Términos</a></li>
      </ul>
    </div>
  </div>

  <div class="container border-t py-6 text-xs text-tane-muted flex flex-col md:flex-row gap-2 justify-between">
    <p>© {year} Tane Solutions. Todos los derechos reservados.</p>
