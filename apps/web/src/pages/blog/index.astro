---
import { getCollection, type CollectionEntry } from 'astro:content'
import Base from '~/layouts/Base.astro'
import Header from '~/components/Header.astro'
import Footer from '~/components/Footer.astro'

type BlogPost = CollectionEntry<'blog'>

const posts: BlogPost[] = (
  await getCollection('blog', ({ data }: BlogPost) => !data.draft)
).sort(
  (a: BlogPost, b: BlogPost) =>
    b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
)
---

<Base title="Blog" description="Estrategia, IA y casos de uso reales para tener tus redes sociales activas.">
  <Header />

  <main class="container max-w-3xl py-16">
    <h1 class="text-4xl md:text-5xl font-display font-bold tracking-tight">Blog</h1>
    <p class="mt-4 text-tane-muted">Estrategia, IA y casos reales.</p>

    <div class="mt-12 space-y-6">
      {
        posts.map((post: BlogPost) => (
          <a
            href={`/blog/${post.slug}`}
            class="block rounded-xl border bg-card p-6 hover:border-tane-primary transition"
          >
            <p class="text-xs text-tane-muted">
              {post.data.publishedAt.toLocaleDateString('es-ES', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </p>
            <h2 class="text-xl font-display font-semibold mt-1">{post.data.title}</h2>
            <p class="text-tane-muted text-sm mt-2">{post.data.description}</p>
            <div class="flex flex-wrap gap-2 mt-3">
              {post.data.tags.map((tag: string) => (
                <span class="text-xs border rounded-full px-2 py-0.5">#{tag}</span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </main>

  <Footer />
</Base>
