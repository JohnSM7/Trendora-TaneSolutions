---
import Base from '~/layouts/Base.astro'
import Header from '~/components/Header.astro'
import Footer from '~/components/Footer.astro'

const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://trendora.tanesolutions.com/app'

const features = [
  {
    title: 'Genera con IA entrenada con tu marca',
    body: 'Brand kit propio + GPT-4o-mini + DALL-E. La IA aprende tu tono, paleta y estilo y adapta cada post a la red en la que va.',
    icon: '🪄',
    span: 'md:col-span-2',
    highlight: 'Adapta el mismo tema al estilo nativo de cada plataforma',
  },
  {
    title: 'Programa en un calendario',
    body: 'Vista mensual, semanal o por canal. Arrastra y suelta para reagendar.',
    icon: '📅',
  },
  {
    title: 'Aprueba con un toque',
    body: 'El cliente recibe un link único y aprueba o pide cambios. Sin cuenta, sin fricción.',
    icon: '✅',
  },
  {
    title: 'Publica en 12 redes',
    body: 'Instagram, Facebook, LinkedIn, TikTok, X, Threads, YouTube, Pinterest, GBP, Bluesky, Reddit y Telegram.',
    icon: '🚀',
    span: 'md:col-span-2',
    highlight: 'Una conexión, todas las redes',
  },
]

const platforms = [
  { name: 'Instagram', icon: '📷', color: 'from-pink-500 to-rose-500' },
  { name: 'Facebook', icon: 'f', color: 'from-blue-600 to-blue-500' },
  { name: 'LinkedIn', icon: 'in', color: 'from-sky-700 to-sky-600' },
  { name: 'TikTok', icon: '♪', color: 'from-zinc-900 to-zinc-700' },
  { name: 'X', icon: '𝕏', color: 'from-zinc-900 to-zinc-700' },
  { name: 'Threads', icon: '@', color: 'from-zinc-900 to-zinc-700' },
  { name: 'YouTube', icon: '▶', color: 'from-red-600 to-red-500' },
  { name: 'Pinterest', icon: 'P', color: 'from-rose-700 to-rose-600' },
  { name: 'GBP', icon: 'G', color: 'from-blue-500 to-emerald-500' },
]

const steps = [
  {
    n: '01',
    title: 'Escribe un tema',
    body: 'Cuéntale a la IA la idea — ella decide el tono, formato, hashtags y CTA según tu brand kit.',
    img: '/screenshots/studio.png',
    label: 'Studio IA',
  },
  {
    n: '02',
    title: 'Apruébalo en un clic',
    body: 'Tu cliente abre un link público y aprueba o pide cambios. Sin cuenta, sin fricción.',
    img: '/screenshots/approval.png',
    label: 'Aprobación',
  },
  {
    n: '03',
    title: 'Se publica solo',
    body: 'Programa el día y la hora. Trendora publica automáticamente en todas las redes activas.',
    img: '/screenshots/calendar.png',
    label: 'Calendario',
  },
]

const testimonials = [
  {
    quote: 'Antes pasaba 5 horas a la semana editando reels y fotos. Ahora dedico 30 min los lunes y tengo todo el mes publicado.',
    author: 'María',
    role: 'Pizzería Tradizionale',
    avatar: 'https://api.dicebear.com/7.x/initials/svg?seed=MR&backgroundColor=ffd166',
  },
  {
    quote: 'Llevamos 12 cuentas de cliente desde Trendora. La aprobación por link nos ha ahorrado mil emails de "esto cámbialo".',
    author: 'Daniel Ruiz',
    role: 'Agencia Notable',
    avatar: 'https://api.dicebear.com/7.x/initials/svg?seed=DR&backgroundColor=8a86ff',
  },
  {
    quote: 'La calidad de la imagen generada es lo que más me sorprendió. Parece que tengo un fotógrafo en plantilla.',
    author: 'Laura',
    role: 'Café Boreal',
    avatar: 'https://api.dicebear.com/7.x/initials/svg?seed=LB&backgroundColor=06d6a0',
  },
]
---

<Base title="Trendora">
  <Header />

  <main>
    <!-- ============ HERO ============ -->
    <section class="relative overflow-hidden">
      <!-- decorative gradient blob -->
      <div
        aria-hidden="true"
        class="absolute -top-24 -left-24 h-96 w-96 rounded-full bg-tane-primary/20 blur-3xl"
      ></div>
      <div
        aria-hidden="true"
        class="absolute top-1/2 -right-24 h-96 w-96 rounded-full bg-tane-accent/20 blur-3xl"
      ></div>

      <div class="container relative py-16 md:py-24">
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
          <div class="lg:col-span-6">
            <p class="inline-flex items-center gap-2 rounded-full border bg-tane-primary/5 px-3 py-1 text-xs text-tane-primary mb-6">
              <span class="h-2 w-2 rounded-full bg-tane-accent animate-pulse"></span>
              Lanzamiento privado abierto · plazas limitadas
            </p>

            <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold tracking-tight">
              Tu marca activa
              <span class="text-tane-primary">en todas las redes,</span>
              sin estar tú.
            </h1>

            <p class="mt-6 text-lg text-tane-muted max-w-xl">
              Trendora <strong>genera, programa y publica</strong> todo tu contenido social con IA
              entrenada con tu marca. Tú solo apruebas con un toque.
            </p>

            <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-3">
              <a
                href={APP_URL + '/signup'}
                class="inline-flex h-12 items-center justify-center rounded-md bg-tane-primary px-8 text-base font-medium text-white hover:bg-tane-primary/90 transition shadow-lg shadow-tane-primary/20"
              >
                Empezar prueba gratis · 14 días
              </a>
              <a
                href="#how-it-works"
                class="inline-flex h-12 items-center justify-center rounded-md border px-6 text-base font-medium hover:bg-accent transition"
              >
                Ver cómo funciona
              </a>
            </div>

            <p class="mt-4 text-xs text-tane-muted">
              Sin tarjeta · Cancela cuando quieras
            </p>

            <!-- Mini stats -->
            <div class="mt-10 grid grid-cols-3 gap-6 max-w-md">
              <div>
                <p class="text-2xl font-display font-bold">12</p>
                <p class="text-xs text-tane-muted">Redes sociales</p>
              </div>
              <div>
                <p class="text-2xl font-display font-bold">5h</p>
                <p class="text-xs text-tane-muted">/sem ahorradas</p>
              </div>
              <div>
                <p class="text-2xl font-display font-bold">€29</p>
                <p class="text-xs text-tane-muted">/mes desde</p>
              </div>
            </div>
          </div>

          <!-- HERO mockup -->
          <div class="lg:col-span-6 relative">
            <div class="relative">
              <!-- floating badges -->
              <div
                class="absolute -top-6 -left-6 z-10 hidden md:flex items-center gap-2 bg-white border rounded-full pl-1 pr-4 py-1 shadow-xl text-xs"
              >
                <span class="grid h-7 w-7 place-items-center rounded-full bg-tane-accent/20 text-tane-accent">✨</span>
                <span class="font-medium">Generado en 2.3s</span>
              </div>
              <div
                class="absolute -bottom-4 -right-4 z-10 hidden md:flex items-center gap-2 bg-white border rounded-full pl-1 pr-4 py-1 shadow-xl text-xs"
              >
                <span class="grid h-7 w-7 place-items-center rounded-full bg-emerald-500/20 text-emerald-600">✓</span>
                <span class="font-medium">Publicado en 4 redes</span>
              </div>

              <!-- Mockup card -->
              <div class="relative rounded-2xl border bg-card shadow-2xl overflow-hidden ring-1 ring-black/5">
                <!-- browser chrome -->
                <div class="flex items-center gap-1.5 px-4 py-3 border-b bg-muted/40">
                  <span class="h-3 w-3 rounded-full bg-red-400/60"></span>
                  <span class="h-3 w-3 rounded-full bg-yellow-400/60"></span>
                  <span class="h-3 w-3 rounded-full bg-green-400/60"></span>
                  <div class="ml-3 flex-1 max-w-xs h-6 rounded bg-background border text-[10px] flex items-center px-2 text-tane-muted truncate">
                    trendora.tanesolutions.com/app/studio
                  </div>
                </div>
                <img
                  src="/screenshots/studio.png"
                  alt="Studio IA de Trendora generando un post para Instagram"
                  class="w-full block"
                  loading="eager"
                  fetchpriority="high"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ PLATAFORMAS STRIP ============ -->
    <section class="border-y bg-muted/30">
      <div class="container py-10">
        <p class="text-center text-xs uppercase tracking-wider text-tane-muted mb-6">
          Publica en las redes que importan a tu negocio
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4 md:gap-8">
          {
            platforms.map((p) => (
              <div class="flex items-center gap-2 opacity-70 hover:opacity-100 transition">
                <span
                  class={`grid h-8 w-8 place-items-center rounded-md text-white text-sm font-bold bg-gradient-to-br ${p.color}`}
                >
                  {p.icon}
                </span>
                <span class="text-sm font-medium">{p.name}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ HOW IT WORKS ============ -->
    <section id="how-it-works" class="container py-20 md:py-28">
      <div class="max-w-2xl mx-auto text-center mb-16">
        <p class="inline-flex items-center gap-2 rounded-full bg-tane-primary/10 px-3 py-1 text-xs text-tane-primary mb-4">
          Cómo funciona
        </p>
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">
          Un mes de contenido en una hora
        </h2>
        <p class="mt-4 text-tane-muted">
          Trendora hace el 90% del trabajo. Tú solo das luz verde.
        </p>
      </div>

      <div class="space-y-20 md:space-y-32">
        {
          steps.map((step, i) => (
            <div
              class={`grid lg:grid-cols-2 gap-10 items-center ${i % 2 === 1 ? 'lg:[&>*:first-child]:order-2' : ''}`}
            >
              <div>
                <p class="text-6xl md:text-7xl font-display font-bold text-tane-primary/20 leading-none mb-2">
                  {step.n}
                </p>
                <p class="text-xs uppercase tracking-wider text-tane-primary mb-3">
                  {step.label}
                </p>
                <h3 class="text-2xl md:text-3xl font-display font-bold tracking-tight mb-4">
                  {step.title}
                </h3>
                <p class="text-tane-muted leading-relaxed text-lg">{step.body}</p>
              </div>

              <div class="relative">
                <div
                  aria-hidden="true"
                  class={`absolute -inset-4 rounded-3xl blur-2xl opacity-40 ${
                    i === 0
                      ? 'bg-gradient-to-br from-tane-primary/40 to-violet-300'
                      : i === 1
                        ? 'bg-gradient-to-br from-emerald-300 to-tane-accent/40'
                        : 'bg-gradient-to-br from-amber-300 to-tane-primary/40'
                  }`}
                ></div>
                <div class="relative rounded-2xl border bg-card shadow-2xl overflow-hidden ring-1 ring-black/5">
                  <img
                    src={step.img}
                    alt={`Captura de ${step.title}`}
                    loading="lazy"
                    class="w-full block"
                  />
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ============ BENTO FEATURES ============ -->
    <section id="features" class="container py-20 md:py-28 border-t">
      <div class="max-w-2xl mx-auto text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">
          Todo lo que necesitas para tener tus redes activas
        </h2>
        <p class="mt-4 text-tane-muted">
          Una plataforma completa para crear, aprobar, programar y medir contenido en redes.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {
          features.map((f) => (
            <div
              class={`relative rounded-2xl border bg-card p-7 hover:border-tane-primary/30 hover:shadow-lg transition group overflow-hidden ${f.span ?? ''}`}
            >
              <div class="text-3xl mb-4">{f.icon}</div>
              <h3 class="font-display font-semibold text-lg mb-2">{f.title}</h3>
              <p class="text-sm text-tane-muted leading-relaxed">{f.body}</p>
              {f.highlight && (
                <p class="mt-4 inline-flex items-center gap-2 text-xs text-tane-primary">
                  <span class="h-1.5 w-1.5 rounded-full bg-tane-primary" />
                  {f.highlight}
                </p>
              )}
            </div>
          ))
        }

        <!-- Bento card especial: brand kit -->
        <div class="relative rounded-2xl border bg-gradient-to-br from-tane-primary/5 via-card to-tane-accent/5 p-7 md:col-span-2 overflow-hidden group">
          <div class="text-3xl mb-4">🎨</div>
          <h3 class="font-display font-semibold text-lg mb-2">Brand kit que se enseña a la IA</h3>
          <p class="text-sm text-tane-muted leading-relaxed max-w-md">
            Subes tu logo, paleta, tipografías y tono. La IA genera contenido que parece escrito y
            diseñado por tu equipo, no por un robot genérico.
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            <span class="text-xs px-3 py-1 rounded-full bg-tane-primary/10 text-tane-primary">Tono cercano</span>
            <span class="text-xs px-3 py-1 rounded-full bg-tane-primary/10 text-tane-primary">Voz informal</span>
            <span class="text-xs px-3 py-1 rounded-full bg-tane-primary/10 text-tane-primary">Sin emojis</span>
            <span class="text-xs px-3 py-1 rounded-full bg-tane-primary/10 text-tane-primary">Paleta cálida</span>
          </div>
        </div>

        <!-- Bento card: analytics -->
        <div class="relative rounded-2xl border bg-card p-7 overflow-hidden">
          <div class="text-3xl mb-4">📊</div>
          <h3 class="font-display font-semibold text-lg mb-2">Analítica accionable</h3>
          <p class="text-sm text-tane-muted leading-relaxed">
            No "alcance" ni "impresiones". Te decimos qué publicar y cuándo para vender más.
          </p>
        </div>
      </div>
    </section>

    <!-- ============ TESTIMONIOS ============ -->
    <section class="container py-20 md:py-24">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">
          Hecho con negocios reales
        </h2>
        <p class="mt-4 text-tane-muted">
          Restaurantes, agencias y comercios que recuperan sus tardes.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {
          testimonials.map((t) => (
            <figure class="rounded-2xl border bg-card p-6 hover:shadow-lg transition">
              <blockquote class="text-sm leading-relaxed text-foreground">
                <span class="text-2xl text-tane-primary leading-none">"</span>
                {t.quote}
              </blockquote>
              <figcaption class="mt-5 flex items-center gap-3">
                <img
                  src={t.avatar}
                  alt={t.author}
                  width="40"
                  height="40"
                  class="h-10 w-10 rounded-full bg-muted"
                  loading="lazy"
                />
                <div>
                  <p class="text-sm font-medium">{t.author}</p>
                  <p class="text-xs text-tane-muted">{t.role}</p>
                </div>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </section>

    <!-- ============ VERTICALES ============ -->
    <section class="container py-20 md:py-24 border-t">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">
          Hecho a medida para tu sector
        </h2>
        <p class="mt-4 text-tane-muted">
          Plantillas, prompts y assets afinados para cada tipo de negocio.
        </p>
      </div>

      <div class="grid gap-3 md:grid-cols-3 lg:grid-cols-4 max-w-5xl mx-auto">
        {
          [
            { name: 'Restaurantes', emoji: '🍽️' },
            { name: 'Cafeterías', emoji: '☕' },
            { name: 'Bares', emoji: '🍷' },
            { name: 'Gimnasios', emoji: '💪' },
            { name: 'Clínicas dentales', emoji: '🦷' },
            { name: 'Peluquerías', emoji: '✂️' },
            { name: 'Tiendas físicas', emoji: '🛍️' },
            { name: 'SaaS B2B', emoji: '💻' },
          ].map((v) => (
            <a
              href={`/verticales/${v.name
                .toLowerCase()
                .normalize('NFD')
                .replace(/[̀-ͯ]/g, '')
                .replace(/\s+/g, '-')}`}
              class="rounded-xl border p-4 text-sm hover:border-tane-primary hover:bg-tane-primary/5 transition group flex items-center gap-3"
            >
              <span class="text-xl">{v.emoji}</span>
              <span class="flex-1">{v.name}</span>
              <span class="text-tane-muted group-hover:text-tane-primary transition">→</span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- ============ CTA FINAL ============ -->
    <section class="container py-16 md:py-24">
      <div class="relative rounded-3xl bg-gradient-to-br from-tane-primary via-tane-primary to-violet-700 text-white p-10 md:p-16 overflow-hidden">
        <!-- Decorative pattern -->
        <div
          aria-hidden="true"
          class="absolute inset-0 opacity-30"
          style="background-image: radial-gradient(circle at 25% 30%, rgba(255,255,255,0.15) 1px, transparent 1px), radial-gradient(circle at 75% 75%, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 40px 40px, 50px 50px;"
        >
        </div>

        <div class="relative grid md:grid-cols-2 gap-10 items-center">
          <div>
            <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">
              ¿Listo para recuperar tus tardes?
            </h2>
            <p class="mt-4 text-white/80 max-w-xl">
              Empieza gratis durante 14 días, sin tarjeta. Si no te convence, no pagas nada y te
              ayudamos a exportar todo tu contenido.
            </p>
            <div class="mt-8 flex flex-col sm:flex-row gap-3">
              <a
                href={APP_URL + '/signup'}
                class="inline-flex h-12 items-center justify-center rounded-md bg-white px-8 text-base font-medium text-tane-primary hover:bg-white/90 transition"
              >
                Crear mi cuenta gratis
              </a>
              <a
                href="/contacto"
                class="inline-flex h-12 items-center justify-center rounded-md border border-white/40 px-8 text-base font-medium text-white hover:bg-white/10 transition"
              >
                Hablar con un humano
              </a>
            </div>
          </div>

          <!-- Floating mockup small -->
          <div class="hidden md:block relative">
            <div
              aria-hidden="true"
              class="absolute -inset-2 rounded-2xl bg-white/10 blur-xl"
            ></div>
            <div class="relative rounded-2xl bg-white shadow-2xl overflow-hidden ring-1 ring-black/10 -rotate-2 hover:rotate-0 transition-transform duration-500">
              <img
                src="/screenshots/dashboard.png"
                alt="Dashboard de Trendora"
                loading="lazy"
                class="w-full block"
              />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
