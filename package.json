{
  "name": "tane-social-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Trendora — Plataforma SaaS de automatización de redes sociales con IA, by Tane Solutions",
  "author": "Tane Solutions <hola@tanesolutions.com>",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@tane/web",
    "dev:app": "turbo run dev --filter=@tane/app",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,vue,astro,md,json}\"",
    "db:push": "pnpm --filter @tane/db push",
    "db:types": "pnpm --filter @tane/db gen-types",
    "inngest:dev": "pnpm --filter @tane/app inngest:dev"
  },
  "devDependencies": {
    "turbo": "^2.9.14",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "dotenv": "^17.0.0",
    "stripe": "^17.5.0"
  },
  "pnpm": {
    "overrides": {
      "cookie": "^0.7.2"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "protobufjs",
      "sharp",
      "supabase",
      "vue-demi"
    ]
  }
}
