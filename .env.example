# ============================================================================
# Trendora — Variables de entorno
# Copia este archivo a .env y rellena con tus credenciales reales.
# NUNCA hagas commit del archivo .env real.
# ============================================================================

# --- Entorno ---
NODE_ENV=development
APP_URL=http://localhost:3000
MARKETING_URL=http://localhost:4321

# --- Supabase ---
# Crear proyecto en https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...
# Para Nuxt (lado cliente)
NUXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NUXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# --- IA ---
# Claude (texto) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI (fallback / embeddings) — https://platform.openai.com
OPENAI_API_KEY=sk-...
# Replicate (Nano Banana, Flux, etc.) — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...
# Google AI (Veo 3, Gemini) — https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=...

# --- Ayrshare (publicación social multi-tenant) ---
# https://app.ayrshare.com → API
AYRSHARE_API_KEY=...
# Private key generada para JWT (Business plan) — formato PEM completo
AYRSHARE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
AYRSHARE_DOMAIN=tane-social
# Webhook secret (configurar en Ayrshare dashboard)
AYRSHARE_WEBHOOK_SECRET=whsec_...

# --- Stripe ---
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs (crear en Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_AGENCY_YEARLY=price_...
STRIPE_METER_AI_CREDITS=mtr_...

# --- Email transaccional ---
# https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Trendora <noreply@trendora.tanesolutions.com>"

# --- Inngest (jobs en background) ---
# https://app.inngest.com
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=signkey-prod-...

# --- Observabilidad ---
SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://eu.posthog.com

# --- Seguridad ---
# Generar con: openssl rand -base64 32
NUXT_SESSION_PASSWORD=cambia_esto_por_una_cadena_de_32+_caracteres_aleatorios
